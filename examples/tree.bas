10 MODE 1
20 CLG
30 MOVE 640, 0
40 GCOL 0, 2
50 PROCtree(640, 100, 250, PI/2)
60 PRINT "THE RECURSIVE FOREST"
70 END
80 DEF PROCtree(X, Y, L, A)
85 LOCAL X2, Y2
90 IF L < 10 THEN ENDPROC
100 X2 = X + L * COS(A)
110 Y2 = Y + L * SIN(A)
120 MOVE X, Y
130 DRAW X2, Y2
140 PROCtree(X2, Y2, L * 0.7, A + PI/6)
150 PROCtree(X2, Y2, L * 0.7, A - PI/6)
160 ENDPROC