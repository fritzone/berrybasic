10 MODE 1
20 CLG
30 CX = 640 : CY = 512
40 R1 = 300 : R2 = 120 : D = 180
50 GCOL 0,1
60 FOR T = 0 TO 20*PI STEP 0.1
70 X = (R1-R2)*COS(T) + D*COS((R1-R2)*T/R2)
80 Y = (R1-R2)*SIN(T) - D*SIN((R1-R2)*T/R2)
90 IF T=0 THEN MOVE CX+X, CY+Y ELSE DRAW CX+X, CY+Y
100 GCOL 0, (INT(T*2) MOD 7) + 1
110 NEXT
120 PRINT "PRESS ANY KEY"
130 K = GET
